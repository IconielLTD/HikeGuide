<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. Paired with allowBackup="false", this
     keeps the user's trip log (location history) and caches off cloud backup
     and out of device-to-device transfers. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
